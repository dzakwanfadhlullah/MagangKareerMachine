# MagangKareer Engine Configuration
# Copy this file to .env and adjust as needed

# Database path (default: data/magangkareer.db)
DB_PATH=data/magangkareer.db

# Export directory (default: exports/)
EXPORT_DIR=exports

# Fetch timeout in seconds
FETCH_TIMEOUT=15

# Max search results per query
MAX_RESULTS_PER_QUERY=20

# Fast Research search provider:
# - auto: try official providers when keys exist, then fallback to DDG
# - ddg: free DuckDuckGo/DDGS fallback
# - brave / serper / tavily: official provider, requires key below
SEARCH_PROVIDER=auto

# Optional official search provider keys. Leave blank to skip.
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=
